<div class="edc-dialog edc-calculateur">
  <div class="form-group">
    <label>Nom du rituel</label>
    <input type="text" name="nom" value="Nouveau Rituel">
  </div>

  {{#if optionsChamp.length}}
  <div class="form-group">
    <label>Champ lié</label>
    <select name="champ">
      {{#each optionsChamp}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
    </select>
  </div>
  {{else}}
  <p class="edc-hint">Aucun Champ pour l'instant — ajoutez-en un avant de créer un rituel.</p>
  {{/if}}

  <p class="edc-hint">Difficulté de base : {{difficulteBase}}. Chaque catégorie choisie ajoute ses points de Majoration à la difficulté finale du rituel (p.250).</p>

  <div class="form-group">
    <label>Portée</label>
    <select name="portee">
      {{#each optionsPortee}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Durée</label>
    <select name="duree">
      {{#each optionsDuree}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Dégâts / soins</label>
    <select name="degatsSoins">
      {{#each optionsDegatsSoins}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Cibles</label>
    <select name="cibles">
      {{#each optionsCibles}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Bonus / malus octroyé</label>
    <select name="bonusMalus">
      {{#each optionsBonusMalus}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Invocation</label>
    <select name="invocation">
      {{#each optionsInvocation}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Effets spéciaux (p.251, optionnel)</label>
    <div class="edc-checklist">
      {{#each effetsSpeciaux}}
      <label class="edc-checkbox">
        <input type="checkbox" name="effet-{{this.id}}" value="on">
        {{this.label}} (+{{this.points}})
      </label>
      {{/each}}
    </div>
  </div>
</div>
