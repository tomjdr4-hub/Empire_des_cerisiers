<div class="edc-dialog edc-calculateur">
  <div class="form-group">
    <label>Nom de la technique</label>
    <input type="text" name="nom" value="Nouvelle Technique">
  </div>

  {{#if optionsAspect.length}}
  <div class="form-group">
    <label>Aspect lié</label>
    <select name="aspect">
      {{#each optionsAspect}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
    </select>
  </div>
  {{else}}
  <p class="edc-hint">Aucun Aspect pour l'instant — ajoutez-en un dans l'onglet Voie avant de créer une technique.</p>
  {{/if}}

  {{#if lignes.length}}
  <table class="edc-table">
    <thead><tr><th>Aspect</th><th>Niveau</th><th>Puissance gagnée à ce niveau</th><th>Déjà utilisée</th></tr></thead>
    <tbody>
      {{#each lignes}}
      <tr><td>{{this.nom}}</td><td>{{this.niveau}}</td><td>{{this.puissanceGagneeAuNiveau}}</td><td>{{this.puissanceDepensee}}</td></tr>
      {{/each}}
    </tbody>
  </table>
  <p class="edc-hint">Les points non dépensés au niveau actuel sont perdus au passage au niveau suivant (p.212-214) — ce tableau est une aide, pas un solde suivi automatiquement.</p>
  {{/if}}

  <h4>Construire la technique (p.216)</h4>
  <div class="form-group">
    <label>Portée</label>
    <select name="portee">
      {{#each optionsPortee}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Durée</label>
    <select name="duree">
      {{#each optionsDuree}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Dégâts / soins</label>
    <select name="degatsSoins">
      {{#each optionsDegatsSoins}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Cibles</label>
    <select name="cibles">
      {{#each optionsCibles}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Bonus / malus octroyé</label>
    <select name="bonusMalus">
      {{#each optionsBonusMalus}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>Invocation</label>
    <select name="invocation">
      {{#each optionsInvocation}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
    </select>
  </div>
</div>
