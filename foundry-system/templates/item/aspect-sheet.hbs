<div class="edc-item-sheet">
  <label>Nom
    <input type="text" name="name" value="{{item.name}}">
  </label>
  <label>Voie liée
    <input type="text" name="system.voie" value="{{system.voie}}">
  </label>
  <p><strong>Niveau :</strong> {{system.niveau}}</p>
  <p class="edc-hint">Le niveau se change via l'assistant "Création de personnage" ou "Montée en compétences" de la fiche, pas ici (p.212-214).</p>
  <label>Description
    <textarea name="system.description">{{system.description}}</textarea>
  </label>
</div>
